Mplus VERSION 8.6
MUTHEN & MUTHEN
03/02/2026   5:39 PM

INPUT INSTRUCTIONS

  TITLE:
          Causal rGE on differential parenting;

  DATA:
          FILE IS "c:\Repo\data_local\withinfamrGE_addh.csv";




  VARIABLE:
          Names are AID FAM GPAIRID GID GFAM
          pgs ANCESTRY sex age_1 age_3
          white african native asian other hispanic
          income par_ed par_age
          par_sex par_marry
          bad_temper pr_parent pr_child del_peer scho_con
          asb_1 asb_3 sub_1 sub_3
          par_sub autonomy par_involv adhd;

          usevariables are FAM
           pgs sex age_1 !age_3
           pr_parent pr_child del_peer scho_con
           asb_1 sub_1
           asb_3 sub_3
           pgs_m sex_m age_1_m !age_3_m
           income_m par_ed_m
           afr eas his;

          CLUSTER IS FAM;

          WITHIN ARE
           pgs sex age_1 !age_3
           ;

          BETWEEN ARE
          pgs_m sex_m age_1_m !age_3_m
          income_m par_ed_m
          afr eas his;


          Missing are .;


  DEFINE:
          del_peer = -del_peer;
          afr = 0;
          eas = 0;
          his = 0;
          IF(ANCESTRY EQ 2)THEN afr = 1;
          IF(ANCESTRY EQ 3)THEN eas = 1;
          IF(ANCESTRY EQ 4)THEN his = 1;
          income = log(income + 1);
          pgs_m = CLUSTER_MEAN(pgs);
          sex_m = CLUSTER_MEAN(sex);
          age_1_m = CLUSTER_MEAN(age_1);
          !age_3_m = CLUSTER_MEAN(age_3);
          income_m = CLUSTER_MEAN(income);
          par_ed_m = CLUSTER_MEAN(par_ed);
          CENTER pgs sex age_1(GROUPMEAN);
          !CENTER age_3(GROUPMEAN);

  ANALYSIS:

          TYPE = TWOLEVEL RANDOM;
          ESTIMATOR = BAYES;
          !ESTIMATOR=WLSM;
          !BOOTSTRAP = 20000;
          PROC = 10;
          CHAINS = 10;
          FBITERATIONS= 30000;

  MODEL:

          %WITHIN%

          pr_parent pr_child del_peer scho_con asb_3 sub_3 asb_1 sub_1 ON sex age_1;
          pr_parent ON pgs (w1);
          pr_child ON pgs (w2);
          del_peer ON pgs (w3);
          scho_con ON pgs (w4);
          asb_1 ON pgs;
          sub_1 ON pgs;
          asb_3 ON pgs;
          sub_3 ON pgs;

          [pgs sex age_1 @0];
          pgs sex age_1 ;
          pgs sex age_1 WITH pgs sex age_1 ;

          %BETWEEN%
          pr_parent pr_child del_peer scho_con asb_1 sub_1 asb_3 sub_3;
          pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          pr_parent ON pgs_m (b1);
          pr_child ON pgs_m (b2);
          del_peer ON pgs_m (b3);
          scho_con ON pgs_m (b4);

          pr_parent ON  sex_m age_1_m income_m par_ed_m afr eas his;
          pr_child ON  sex_m age_1_m income_m par_ed_m afr eas his;
          del_peer ON  sex_m age_1_m income_m par_ed_m afr eas his;
          scho_con ON  sex_m age_1_m income_m par_ed_m afr eas his;
          asb_1 sub_1 ON pgs_m sex_m age_1_m income_m par_ed_m afr eas his;
          asb_3 sub_3 ON pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          pgs_m sex_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;
          age_1_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;
          income_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;
          par_ed_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;
          afr eas his WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

  MODEL CONSTRAINT:

  NEW (d_parent d_child d_peer d_scho);

  d_parent = b1-w1;
  d_child = b2-w2;
  d_peer = b3-w3;
  d_scho = b4-w4;


  OUTPUT: TECH1 TECH8 CINTERVAL;
  PLOT: TYPE = PLOT2;




