Mplus VERSION 7.4
MUTHEN & MUTHEN
04/24/2025  12:16 AM

INPUT INSTRUCTIONS

  TITLE:
          Causal rGE on differential parenting;

  DATA:
          FILE IS "c:\Repo\data_local\withinfamrGE_addh.csv";




  VARIABLE:
          Names are AID FAM GPAIRID GID GFAM
          pgs ANCESTRY sex age_1 age_3
          white african native asian other hispanic
          income par_ed par_age
          par_sex par_marry
          bad_temper pr_parent pr_child del_peer scho_con
          asb_1 asb_3 sub_1 sub_3
          par_sub autonomy par_involv adhd;

          usevariables are FAM
           pgs sex age_1 !age_3
           pr_parent pr_child
           del_peer scho_con
           asb_1 sub_1 adhd
           !sub_3
           pgs_m sex_m age_1_m !age_3_m
           income_m par_ed_m
           afr eas his;

          CLUSTER IS FAM;

          WITHIN ARE
           pgs sex age_1 !age_3
           ;

          BETWEEN ARE
          pgs_m sex_m age_1_m !age_3_m
          income_m par_ed_m
          afr eas his;


          Missing are .;


  DEFINE:
          del_peer = -del_peer;
          afr = 0;
          eas = 0;
          his = 0;
          IF(ANCESTRY EQ 2)THEN afr = 1;
          IF(ANCESTRY EQ 3)THEN eas = 1;
          IF(ANCESTRY EQ 4)THEN his = 1;
          income = log(income + 1);
          pgs_m = CLUSTER_MEAN(pgs);
          sex_m = CLUSTER_MEAN(sex);
          age_1_m = CLUSTER_MEAN(age_1);
          !age_3_m = CLUSTER_MEAN(age_3);
          income_m = CLUSTER_MEAN(income);
          par_ed_m = CLUSTER_MEAN(par_ed);
          CENTER pgs sex age_1(GROUPMEAN);
          !CENTER age_3(GROUPMEAN);

  ANALYSIS:

          TYPE = TWOLEVEL RANDOM;
          ESTIMATOR = BAYES;
          !ESTIMATOR=WLSM;
          !BOOTSTRAP = 20000;
          PROC = 10;
          CHAINS = 10;
          FBITERATIONS= 30000;

  MODEL:

          %WITHIN%

          pr_parent pr_child del_peer scho_con ON sex age_1;
          asb_1 sub_1 adhd ON sex age_1;
          [pgs sex age_1 @0];

          asb_1 ON pgs(aw_asb);
          sub_1 ON pgs(aw_sub);
          adhd ON pgs(aw_adhd);

          pr_parent ON asb_1(b1w_asb);
          pr_parent ON sub_1(b1w_sub);
          pr_parent ON adhd(b1w_adhd);

          pr_parent ON pgs(c1w);

          pr_child ON asb_1(b2w_asb);
          pr_child ON sub_1(b2w_sub);
          pr_child ON adhd(b2w_adhd);

          pr_child ON pgs(c2w);

          del_peer ON asb_1(b3w_asb);
          del_peer ON sub_1(b3w_sub);
          del_peer ON adhd(b3w_adhd);

          del_peer ON pgs(c3w);

          scho_con ON asb_1(b4w_asb);
          scho_con ON sub_1(b4w_sub);
          scho_con ON adhd(b4w_adhd);

          scho_con ON pgs(c4w);

          pr_parent pr_child del_peer scho_con;
          pr_parent pr_child del_peer scho_con WITH pr_parent pr_child del_peer scho_con;

          !sub_1
          asb_1 sub_1 adhd;
          asb_1 sub_1 adhd WITH asb_1 sub_1 adhd;

          pgs sex age_1;
          pgs sex age_1 WITH pgs sex age_1;

          %BETWEEN%

          !*
          pr_parent pr_child del_peer scho_con ON sex_m age_1_m income_m par_ed_m afr eas hi

          asb_1 sub_1 adhd ON sex_m age_1_m income_m par_ed_m afr eas his;


          asb_1 ON pgs_m(ab_asb);
          sub_1 ON pgs_m(ab_sub);
          adhd ON pgs_m(ab_adhd);

          pr_parent ON asb_1(b1b_asb);
          pr_parent ON sub_1(b1b_sub);
          pr_parent ON adhd(b1b_adhd);

          pr_parent ON pgs_m(c1b);

          pr_child ON asb_1(b2b_asb);
          pr_child ON sub_1(b2b_sub);
          pr_child ON adhd(b2b_adhd);

          pr_child ON pgs_m(c2b);

          del_peer ON asb_1(b3b_asb);
          del_peer ON sub_1(b3b_sub);
          del_peer ON adhd(b3b_adhd);

          del_peer ON pgs(c3b);

          scho_con ON asb_1(b4b_asb);
          scho_con ON sub_1(b4b_sub);
          scho_con ON adhd(b4b_adhd);

          scho_con ON pgs(c4b);

          *!

          pr_parent pr_child del_peer scho_con;
          !pr_parent pr_child del_peer scho_con WITH pr_parent pr_child del_peer scho_con;

          asb_1 sub_1 adhd;
          !asb_1 sub_1 adhd WITH asb_1 sub_1 adhd;


          pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          !pgs_m sex_m WITH pgs_m sex_m age_1_m income_m par_ed_m;
          !age_1_m WITH pgs_m sex_m age_1_m income_m par_ed_m;
          !income_m par_ed_m WITH pgs_m sex_m age_1_m income_m par_ed_m;

          !afr eas his WITH pgs_m sex_m age_1_m income_m par_ed_m;
          !afr eas his WITH afr eas his;


          pr_parent WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          pr_parent WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          pr_child WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          pr_child WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          del_peer WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          del_peer WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          scho_con WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          scho_con WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          asb_1 WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          asb_1 WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          sub_1 WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          sub_1 WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          adhd WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          adhd WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          pgs_m WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          pgs_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          sex_m WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          sex_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          age_1_m WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          age_1_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          income_m WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          income_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          par_ed_m WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          par_ed_m WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          afr WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          afr WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          eas WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          eas WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;

          his WITH pr_parent pr_child del_peer scho_con asb_1 sub_1 adhd;
          his WITH pgs_m sex_m age_1_m income_m par_ed_m afr eas his;



  MODEL CONSTRAINT:

  NEW(iwa1asb iwa1sub iwa1adhd
      tw1
      pwa1asb pwa1sub pwa1adhd
      totw1 ptotw1

      iwa2asb iwa2sub iwa2adhd
      tw2
      pwa2asb pwa2sub pwa2adhd
      totw2 ptotw2

      iwa3asb iwa3sub iwa3adhd
      tw3
      pwa3asb pwa3sub pwa3adhd
      totw3 ptotw3

      iwa4asb iwa4sub iwa4adhd
      tw4
      pwa4asb pwa4sub pwa4adhd
      totw4 ptotw4
      );

      iwa1asb = aw_asb*b1w_asb;
      iwa1sub = aw_sub*b1w_sub;
      iwa1adhd = aw_adhd*b1w_adhd;

      totw1 = iwa1asb + iwa1sub + iwa1adhd;

      tw1 = c1w + iwa1asb + iwa1sub + iwa1adhd;

      pwa1asb = iwa1asb/tw1;
      pwa1sub = iwa1sub/tw1;
      pwa1adhd = iwa1adhd/tw1;

      ptotw1 = pwa1asb + pwa1sub + pwa1adhd;


      iwa2asb = aw_asb*b2w_asb;
      iwa2sub = aw_sub*b2w_sub;
      iwa2adhd = aw_adhd*b2w_adhd;

      totw2 = iwa2asb + iwa2sub + iwa2adhd;


      tw2 = c2w + iwa2asb + iwa2sub + iwa2adhd;

      pwa2asb = iwa2asb/tw2;
      pwa2sub = iwa2sub/tw2;
      pwa2adhd = iwa2adhd/tw2;

      ptotw2 = pwa2asb + pwa2sub + pwa2adhd;

      iwa3asb = aw_asb*b3w_asb;
      iwa3sub = aw_sub*b3w_sub;
      iwa3adhd = aw_adhd*b3w_adhd;

      totw3 = iwa3asb + iwa3sub + iwa3adhd;


      tw3 = c3w + iwa3asb + iwa3sub + iwa3adhd;

      pwa3asb = iwa3asb/tw3;
      pwa3sub = iwa3sub/tw3;
      pwa3adhd = iwa3adhd/tw3;

      ptotw3 = pwa3asb + pwa3sub + pwa3adhd;


      iwa4asb = aw_asb*b4w_asb;
      iwa4sub = aw_sub*b4w_sub;
      iwa4adhd = aw_adhd*b4w_adhd;

      totw4 = iwa4asb + iwa4sub + iwa4adhd;


      tw4 = c4w + iwa4asb + iwa4sub + iwa4adhd;

      pwa4asb = iwa4asb/tw4;
      pwa4sub = iwa4sub/tw4;
      pwa4adhd = iwa4adhd/tw4;

      ptotw4 = pwa4asb + pwa4sub + pwa4adhd;



  OUTPUT: TECH1 TECH8 CINTERVAL;
  PLOT: TYPE = PLOT2;
  !SAVEDATA:
    !BPARAMETERS = bayes.pars;




