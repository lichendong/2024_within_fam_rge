  DEFINE:


  ANALYSIS:

          TYPE = COMPLEX;
          !ESTIMATOR = BAYES;
          ESTIMATOR=WLSMV;
          !BOOTSTRAP = 20000;
          !FBITERATIONS= 20000;
  MODEL:

          !f1 BY PC34A* PC34B PC34C PC34D PC34E PC44A;
          !f2 BY H1WP9* H1WP10 H1PF1 H1PF2 H1PF3 H1PF4 H1PF5;
          !f3 BY H1WP13* H1WP14 H1PF23 H1PF24 H1PF25;
