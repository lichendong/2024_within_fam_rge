          H3RA9 H3RA10 H3RA11 H3RA12 H3RA13 H3RA14 H3RA15
          H3RA16 H3RA17;

          !f11 BY PC10* PC11 PC12 PC17;
          !f12 BY H1WP1* H1WP2 H1WP3 H1WP4 H1WP5 H1WP6 H1WP7;
          !f13 BY H1WP17F* H1WP17G H1WP17H H1WP18F H1WP18G H1WP18H;

          [f14@0];
          f14@1;
          H3RA14 WITH H3RA16;
          H3RA12 WITH H3RA14;
          H3RA13 WITH H3RA17;

  MODEL CONSTRAINT:

  OUTPUT: TECH1 TECH8 MODINDICES(ALL);
  PLOT: TYPE = PLOT3;

  SAVEDATA:
  FILE IS withinfamrGE_factor_score_adhd;

  SAVE = FSCORES;




