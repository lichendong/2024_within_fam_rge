          !f12 BY H1WP1* H1WP2 H1WP3 H1WP4 H1WP5 H1WP6 H1WP7;
          !f13 BY H1WP17F* H1WP17G H1WP17H H1WP18F H1WP18G H1WP18H;

          [f6-f7@0];
          f6-f7@1;
          f6 WITH f7;


  MODEL CONSTRAINT:

  OUTPUT: TECH1 TECH8 MODINDICES;
  PLOT: TYPE = PLOT3;

  SAVEDATA:
  FILE IS withinfamrGE_factor_score_asb;

  SAVE = FSCORES;



